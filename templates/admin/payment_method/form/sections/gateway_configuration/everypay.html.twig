{% set form = hookable_metadata.context.form.gatewayConfig.config %}

<div class="col-12 col-md-6">
    {{ form_row(form.api_username) }}
</div>
<div class="col-12 col-md-6">
    {# A password widget never renders its value — hint that one is stored.
       Render-time attr replaces the type's attr wholesale, so autocomplete
       must be repeated here. #}
    {{ form_row(form.api_secret, form.api_secret.vars.data is not empty ? { attr: { placeholder: '••••••••••••••••', autocomplete: 'new-password' } } : {}) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.account_name) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.environment) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.display_mode) }}
</div>
