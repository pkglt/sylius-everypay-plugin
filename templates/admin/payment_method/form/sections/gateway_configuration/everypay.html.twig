{% set form = hookable_metadata.context.form.gatewayConfig.config %}

<div class="col-12 col-md-6">
    {{ form_row(form.api_username) }}
</div>
<div class="col-12 col-md-6">
    {# A password widget never renders its value — hint that one is stored. #}
    {{ form_row(form.api_secret, form.api_secret.vars.data is not empty ? { attr: { placeholder: '••••••••••••••••' } } : {}) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.account_name) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.environment) }}
</div>
<div class="col-12 col-md-6">
    {{ form_row(form.display_mode) }}
</div>
