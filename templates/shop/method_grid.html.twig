{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}{{ 'pkg_everypay.ui.choose_payment_method'|trans }} | {{ parent() }}{% endblock %}

{% block content %}
    <div class="container my-5" data-test-everypay-method-grid>
        <h1 class="h2 mb-4">{{ 'pkg_everypay.ui.choose_payment_method'|trans }}</h1>

        <div class="row g-3">
            {% for method in payment_methods %}
                <div class="col-6 col-sm-4 col-lg-3">
                    <a href="{{ method.payment_link }}"
                       class="card h-100 text-decoration-none text-reset text-center p-3"
                       data-test-everypay-method="{{ method.source }}">
                        {% if method.logo_url %}
                            <img src="{{ method.logo_url }}" alt="{{ method.display_name }}"
                                 class="mx-auto d-block mb-2" style="max-height: 2.5rem; max-width: 100%;" loading="lazy">
                        {% endif %}
                        <span>{{ method.display_name }}</span>
                    </a>
                </div>
            {% endfor %}
        </div>

        <p class="mt-4">
            <a href="{{ payment_link }}" data-test-everypay-hosted-page-link>
                {{ 'pkg_everypay.ui.all_payment_options'|trans }}
            </a>
        </p>
    </div>
{% endblock %}
