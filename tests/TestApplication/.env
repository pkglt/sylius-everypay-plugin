# Loaded by vendor/sylius/test-application/config/bootstrap.php on top of the
# test application's own .env — values here override it (dotenv-sourced vars
# are overridable by later dotenv loads).

APP_SECRET=pkg_everypay_plugin_test_secret

# SQLite keeps the functional suite runnable on any machine and in CI without
# a database service. %kernel.cache_dir% resolves to <plugin>/var/cache/<env>.
DATABASE_URL="sqlite:///%kernel.cache_dir%/pkg_everypay_test.db"

# Register the plugin bundle and import its real config/config.yaml plus the
# test-only overrides (mocked EveryPay HTTP client, asset loosening).
SYLIUS_TEST_APP_BUNDLES_PATH="tests/TestApplication/bundles.php"
SYLIUS_TEST_APP_CONFIGS_TO_IMPORT="@PkgSyliusEveryPayPlugin/tests/TestApplication/config/config.yaml"

# The PaymentRequest pipeline must run synchronously inside the HTTP request /
# bus dispatch for the functional assertions to observe its effects.
SYLIUS_MESSENGER_TRANSPORT_MAIN_DSN=sync://
SYLIUS_MESSENGER_TRANSPORT_MAIN_FAILED_DSN=in-memory://
SYLIUS_MESSENGER_TRANSPORT_CATALOG_PROMOTION_REMOVAL_DSN=in-memory://
SYLIUS_MESSENGER_TRANSPORT_CATALOG_PROMOTION_REMOVAL_FAILED_DSN=in-memory://
SYLIUS_MESSENGER_TRANSPORT_PAYMENT_REQUEST_DSN=sync://
SYLIUS_MESSENGER_TRANSPORT_PAYMENT_REQUEST_FAILED_DSN=in-memory://
