default:
    # E_ALL without E_DEPRECATED/E_USER_DEPRECATED - vendor deprecations on
    # newer PHP versions must not fail scenario steps.
    calls:
        error_reporting: 8191

    extensions:
        FriendsOfBehat\SymfonyExtension:
            bootstrap: tests/bootstrap.php
            kernel:
                class: Sylius\TestApplication\Kernel
                environment: test
                debug: false

    suites:
        everypay:
            paths:
                - features
            contexts:
                - Tests\Pkg\SyliusEveryPayPlugin\Behat\Context\EveryPayShopContext
                - Tests\Pkg\SyliusEveryPayPlugin\Behat\Context\EveryPayRefundContext
                - Tests\Pkg\SyliusEveryPayPlugin\Behat\Context\EveryPayAdminContext
